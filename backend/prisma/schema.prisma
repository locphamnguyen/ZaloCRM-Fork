generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Top-level org — every resource is scoped to an org
model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teams            Team[]
  users            User[]
  zaloAccounts     ZaloAccount[]
  contacts         Contact[]
  conversations    Conversation[]
  appointments     Appointment[]
  activityLogs     ActivityLog[]
  dailyStats       DailyMessageStat[]
  settings         AppSetting[]
  duplicateGroups  DuplicateGroup[]
  savedReports     SavedReport[]
  integrations     Integration[]
  automationRules  AutomationRule[]
  messageTemplates MessageTemplate[]
  aiConfig         AiConfig?
  aiSuggestions    AiSuggestion[]
  dripCampaigns    DripCampaign[]
  automationLogs   AutomationLog[]
  blocks           Block[]
  customAttrDefs   CustomAttributeDefinition[]
  apiKeys          ApiKey[]

  @@map("organizations")
}

// Team groups within an organization
model Team {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users User[]

  @@map("teams")
}

// CRM user with role-based access
model User {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  teamId       String?  @map("team_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         String   @default("member") // owner, admin, member
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org              Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team             Team?               @relation(fields: [teamId], references: [id])
  zaloAccounts     ZaloAccount[]
  zaloAccess       ZaloAccountAccess[]
  assignedContacts Contact[]           @relation("AssignedContacts")
  appointments     Appointment[]
  repliedMessages  Message[]           @relation("RepliedMessages")
  activityLogs     ActivityLog[]
  messageTemplates MessageTemplate[]
  dripCampaigns    DripCampaign[]      @relation("DripCreatedBy")
  blocks           Block[]             @relation("BlockOwner")
  apiKeys          ApiKey[]            @relation("ApiKeyCreator")

  @@map("users")
}

// Zalo account linked to a user (one user may own multiple Zalo accounts)
model ZaloAccount {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  ownerUserId     String    @map("owner_user_id")
  zaloUid         String?   @unique @map("zalo_uid")
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  phone           String?
  status          String    @default("disconnected") // connected, disconnected, qr_pending
  sessionData     Json?     @map("session_data")
  lastConnectedAt DateTime? @map("last_connected_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  org             Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner           User                @relation(fields: [ownerUserId], references: [id])
  access          ZaloAccountAccess[]
  conversations   Conversation[]
  dailyStats      DailyMessageStat[]
  dripEnrollments DripEnrollment[]

  @@map("zalo_accounts")
}

// ACL: which users can access which Zalo accounts
model ZaloAccountAccess {
  id            String   @id @default(uuid())
  zaloAccountId String   @map("zalo_account_id")
  userId        String   @map("user_id")
  permission    String   @default("read") // read, chat, admin
  createdAt     DateTime @default(now()) @map("created_at")

  zaloAccount ZaloAccount @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, userId])
  @@map("zalo_account_access")
}

// CRM contact record — generic pipeline with status field
model Contact {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloUid          String?   @map("zalo_uid")
  phone            String?
  email            String?   @map("email")
  fullName         String?   @map("full_name")
  crmName          String?   @map("crm_name")
  avatarUrl        String?   @map("avatar_url")
  source           String? // FB, TT, GT, CN, etc.
  sourceDate       DateTime? @map("source_date")
  firstContactDate DateTime? @map("first_contact_date")
  status           String?   @default("new") // new/contacted/interested/converted/lost
  nextAppointment  DateTime? @map("next_appointment")
  assignedUserId   String?   @map("assigned_user_id")
  notes            String?
  tags             Json      @default("[]")
  metadata         Json      @default("{}")
  customAttrs      Json      @default("{}") @map("custom_attrs")
  leadScore        Int       @default(0) @map("lead_score")
  lastActivity     DateTime? @map("last_activity")
  mergedInto       String?   @map("merged_into")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  org               Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedUser      User?            @relation("AssignedContacts", fields: [assignedUserId], references: [id])
  mergedIntoContact Contact?         @relation("ContactMerge", fields: [mergedInto], references: [id])
  mergedFrom        Contact[]        @relation("ContactMerge")
  conversations     Conversation[]
  appointments      Appointment[]
  dripEnrollments   DripEnrollment[]

  @@index([orgId, phone])
  @@index([orgId, zaloUid])
  @@index([orgId, mergedInto])
  @@map("contacts")
}

// B2: per-org reusable content block for drip + broadcast messages
model Block {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  ownerUserId String?   @map("owner_user_id")
  name        String
  type        String    // text | html | image | video | file | link | card
  content     Json      // type-specific payload
  variables   Json      @default("[]") // detected vars cache for UI hints
  isShared    Boolean   @default(false) @map("is_shared")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org         Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner       User?             @relation("BlockOwner", fields: [ownerUserId], references: [id])
  attachments BlockAttachment[]

  @@index([orgId, type, deletedAt])
  @@index([orgId, ownerUserId])
  @@map("blocks")
}

// B2: file/media attachment for a Block
model BlockAttachment {
  id          String   @id @default(uuid())
  blockId     String   @map("block_id")
  orgId       String   @map("org_id") // denormalized for org isolation queries
  kind        String   // image | video | file
  filename    String
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  storagePath String   @map("storage_path") // /<orgId>/blocks/<blockId>/<uuid>-<filename>
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId, position])
  @@map("block_attachments")
}

// B2: per-org schema definition for contact custom attributes
model CustomAttributeDefinition {
  id         String    @id @default(uuid())
  orgId      String    @map("org_id")
  key        String    // e.g. "nhu_cau" — snake_case, [a-z0-9_]
  label      String    // human display
  dataType   String    @map("data_type") // string | number | date | boolean | enum
  enumValues Json?     @map("enum_values") // ["mua","thue"] when dataType=enum
  required   Boolean   @default(false)
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
  @@map("custom_attribute_definitions")
}

// B2: API key for external access (webhooks, integrations)
model ApiKey {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  name            String    // user-facing label
  keyPrefix       String    @map("key_prefix") // first 8 chars for display
  keyHash         String    @unique @map("key_hash") // sha256(secret)
  scopes          Json      @default("[\"read\"]") // ["read","write"]
  lastUsedAt      DateTime? @map("last_used_at")
  expiresAt       DateTime? @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  createdByUserId String?   @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator User?        @relation("ApiKeyCreator", fields: [createdByUserId], references: [id])

  @@index([orgId, revokedAt])
  @@map("api_keys")
}

// B2: per-minute rate-limit tracking per API key
model ApiKeyUsage {
  id       String   @id @default(uuid())
  apiKeyId String   @map("api_key_id")
  bucket   DateTime // truncated to minute
  count    Int      @default(1)

  @@unique([apiKeyId, bucket])
  @@map("api_key_usage")
}

// A chat thread between a Zalo account and a contact (or group)
model Conversation {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloAccountId    String    @map("zalo_account_id")
  contactId        String?   @map("contact_id")
  threadType       String    @default("user") // user, group
  externalThreadId String?   @map("external_thread_id")
  lastMessageAt    DateTime? @map("last_message_at")
  unreadCount      Int       @default(0) @map("unread_count")
  isReplied        Boolean   @default(true) @map("is_replied")
  tab              String    @default("main") @map("tab") // main, other
  createdAt        DateTime  @default(now()) @map("created_at")

  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount     ZaloAccount      @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  contact         Contact?         @relation(fields: [contactId], references: [id])
  messages        Message[]
  aiSuggestions   AiSuggestion[]
  dripEnrollments DripEnrollment[]

  @@unique([zaloAccountId, externalThreadId])
  @@index([orgId, zaloAccountId, isReplied, lastMessageAt])
  @@index([orgId, zaloAccountId, lastMessageAt])
  @@index([orgId, tab, lastMessageAt])
  @@map("conversations")
}

// Individual message within a conversation
model Message {
  id              String    @id @default(uuid())
  conversationId  String    @map("conversation_id")
  zaloMsgId       String?   @map("zalo_msg_id")
  senderType      String    @map("sender_type") // self, contact
  senderUid       String?   @map("sender_uid")
  senderName      String?   @map("sender_name")
  content         String?
  contentType     String    @default("text") @map("content_type") // text, image, file, sticker, voice, video, link
  attachments     Json      @default("[]")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  sentAt          DateTime  @map("sent_at")
  repliedByUserId String?   @map("replied_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  repliedBy      User?           @relation("RepliedMessages", fields: [repliedByUserId], references: [id])
  automationLogs AutomationLog[]

  @@unique([conversationId, zaloMsgId])
  @@map("messages")
}

// Appointment scheduled for a contact
model Appointment {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  contactId       String   @map("contact_id")
  assignedUserId  String?  @map("assigned_user_id")
  appointmentDate DateTime @map("appointment_date")
  appointmentTime String?  @map("appointment_time")
  type            String?
  status          String   @default("scheduled") // scheduled, completed, cancelled, no_show
  notes           String?
  reminderSent    Boolean  @default(false) @map("reminder_sent")
  createdAt       DateTime @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedUser User?        @relation(fields: [assignedUserId], references: [id])

  @@map("appointments")
}

// Audit trail for user actions
model ActivityLog {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// Daily messaging statistics per user per Zalo account
model DailyMessageStat {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  userId            String   @map("user_id")
  zaloAccountId     String   @map("zalo_account_id")
  statDate          DateTime @map("stat_date") @db.Date
  messagesSent      Int      @default(0) @map("messages_sent")
  messagesReceived  Int      @default(0) @map("messages_received")
  messagesUnread    Int      @default(0) @map("messages_unread")
  messagesUnreplied Int      @default(0) @map("messages_unreplied")
  avgResponseTime   Int?     @map("avg_response_time_seconds")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, zaloAccountId, statDate])
  @@map("daily_message_stats")
}

// External service integration (Google Sheets, Telegram, Facebook, Zapier)
model Integration {
  id         String    @id @default(uuid())
  orgId      String    @map("org_id")
  type       String // google_sheets | telegram | facebook | zapier
  name       String    @default("")
  config     Json      @default("{}") // credentials + settings
  enabled    Boolean   @default(true)
  lastSyncAt DateTime? @map("last_sync_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  syncLogs SyncLog[]

  @@map("integrations")
}

// Sync execution log for integrations
model SyncLog {
  id            String   @id @default(uuid())
  integrationId String   @map("integration_id")
  direction     String // import | export
  recordCount   Int      @default(0) @map("record_count")
  status        String // success | partial | failed
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

// Encrypted or plain key-value settings per org
model AppSetting {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  settingKey     String   @map("setting_key")
  valuePlain     String?  @map("value_plain")
  valueEncrypted Bytes?   @map("value_encrypted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, settingKey])
  @@map("app_settings")
}

// Groups of potentially duplicate contacts detected by the intelligence cron
model DuplicateGroup {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  contactIds String[] @map("contact_ids")
  matchType  String   @map("match_type") // phone, zalo_uid, name
  confidence Float    @default(1.0)
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, resolved])
  @@map("duplicate_groups")
}

// Saved analytics report configuration
model SavedReport {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  type      String // conversion_funnel, team_performance, response_time, custom
  config    Json     @default("{}")
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("saved_reports")
}

model AutomationRule {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  name        String
  description String?
  trigger     String
  conditions  Json      @default("[]")
  actions     Json      @default("[]")
  enabled     Boolean   @default(true)
  priority    Int       @default(0)
  runCount    Int       @default(0) @map("run_count")
  lastRunAt   DateTime? @map("last_run_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, trigger, enabled, priority])
  @@map("automation_rules")
}

model MessageTemplate {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  ownerUserId String?  @map("owner_user_id")
  name        String
  content     String
  category    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner     User?        @relation(fields: [ownerUserId], references: [id])
  dripSteps DripStep[]

  @@index([orgId, ownerUserId])
  @@index([orgId, category])
  @@map("message_templates")
}

model AiConfig {
  id        String   @id @default(uuid())
  orgId     String   @unique @map("org_id")
  provider  String   @default("anthropic")
  model     String   @default("claude-sonnet-4-6")
  maxDaily  Int      @default(500) @map("max_daily")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

model AiSuggestion {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  conversationId String   @map("conversation_id")
  messageId      String?  @map("message_id")
  type           String
  content        String
  confidence     Float
  accepted       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([conversationId, createdAt])
  @@index([orgId, type, createdAt])
  @@map("ai_suggestions")
}

// Drip campaign: multi-step automated message sequence
model DripCampaign {
  id                 String   @id @default(uuid())
  orgId              String   @map("org_id")
  name               String
  description        String?
  enabled            Boolean  @default(true)
  windowStart        Int      @default(8) @map("window_start") // hour 0-23
  windowEnd          Int      @default(11) @map("window_end")
  timezone           String   @default("Asia/Ho_Chi_Minh")
  startTrigger       String   @default("manual") @map("start_trigger") // manual | webhook | tag
  startTag           String?  @map("start_tag")
  stopOnReply        Boolean  @default(true) @map("stop_on_reply")
  stopOnTag          String?  @map("stop_on_tag")
  stopOnInactiveDays Int?     @map("stop_on_inactive_days")
  createdBy          String   @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator     User             @relation("DripCreatedBy", fields: [createdBy], references: [id])
  steps       DripStep[]
  enrollments DripEnrollment[]

  @@index([orgId, enabled])
  @@map("drip_campaigns")
}

// Ordered step within a drip campaign
model DripStep {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  stepIndex  Int      @map("step_index") // 0-based
  templateId String?  @map("template_id")
  content    String? // inline fallback
  dayOffset  Int      @map("day_offset") // default = step_index
  createdAt  DateTime @default(now()) @map("created_at")

  campaign DripCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  template MessageTemplate? @relation(fields: [templateId], references: [id])

  @@unique([campaignId, stepIndex])
  @@map("drip_steps")
}

// Enrollment: a contact currently progressing through a drip campaign
model DripEnrollment {
  id             String    @id @default(uuid())
  campaignId     String    @map("campaign_id")
  contactId      String    @map("contact_id")
  conversationId String    @map("conversation_id")
  zaloAccountId  String    @map("zalo_account_id")
  currentStep    Int       @default(0) @map("current_step")
  status         String    @default("active") // active | paused | completed | cancelled | failed
  scheduledAt    DateTime? @map("scheduled_at")
  lastSentAt     DateTime? @map("last_sent_at")
  startedAt      DateTime  @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")
  failReason     String?   @map("fail_reason")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  campaign     DripCampaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact      Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversation Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  zaloAccount  ZaloAccount     @relation(fields: [zaloAccountId], references: [id])
  logs         AutomationLog[]

  @@index([status, scheduledAt])
  @@index([contactId, campaignId, status])
  @@map("drip_enrollments")
}

// Audit log of drip send attempts
model AutomationLog {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  enrollmentId String   @map("enrollment_id")
  stepIndex    Int      @map("step_index")
  messageId    String?  @map("message_id")
  status       String // sent | failed | rate_limited | skipped
  error        String?
  sentAt       DateTime @default(now()) @map("sent_at")

  org        Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  enrollment DripEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  message    Message?       @relation(fields: [messageId], references: [id])

  @@index([enrollmentId, sentAt])
  @@index([orgId, sentAt])
  @@map("automation_logs")
}
